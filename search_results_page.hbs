<!DOCTYPE html>
<html lang="{{locale}}" dir="{{page_dir}}">
  {{partial 'document_head'}}
  <body>

    {{partial 'header'}}

    <div class="page-hero">
      <div class="page-hero__inner">
        <h1 class="page-hero__title">Search results</h1>
        <!-- Zendesk search widget -->
        <div class="search-bar-wrap">
          <span class="search-bar-icon" aria-hidden="true">
            <svg width="18" height="18" viewBox="0 0 20 20" fill="none">
              <circle cx="9" cy="9" r="6.5" stroke="#aab0b8" stroke-width="1.8"/>
              <path d="M14 14l3.5 3.5" stroke="#aab0b8" stroke-width="1.8" stroke-linecap="round"/>
            </svg>
          </span>
          {{search}}
        </div>
      </div>
      <div class="page-hero__wave" aria-hidden="true">
        <svg viewBox="0 0 1440 56" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M0 56h1440V28C1200 0 960 56 720 56S240 0 0 28V56z" fill="#FBFBFB"/>
        </svg>
      </div>
    </div>

    <nav class="breadcrumb" aria-label="Breadcrumb">{{breadcrumbs}}</nav>

    <div class="page-wrap">

      {{#if query}}
        <p class="search-results-count">
          {{#if results_count}}
            <strong>{{results_count}}</strong> {{t 'results_for' query=query}}
          {{else}}
            {{t 'no_results_for' query=query}}
          {{/if}}
        </p>
      {{/if}}

      {{#each results}}
        <div class="search-result-item">
          <h3><a href="{{url}}">{{title}}</a></h3>
          {{#if snippet}}<p>{{snippet}}</p>{{/if}}
          <p class="result-meta">{{section.full_path}}</p>
        </div>
      {{/each}}

    </div>

    {{partial 'footer'}}

  </body>
</html>
