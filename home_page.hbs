<!DOCTYPE html>
<html lang="{{locale}}" dir="{{page_dir}}">
  {{partial 'document_head'}}
  <body>

    {{partial 'header'}}

    <!-- ═══════════════════════════════════════════
         HERO
    ═══════════════════════════════════════════ -->
    <section class="hero" aria-label="Page header">
      <div class="hero__inner">

        <!-- App pill — text updated by script.js -->
        <div class="hero__app-pill" id="hero-app-pill">
          <span class="hero__app-pill-dot" aria-hidden="true">✦</span>
          <span id="hero-app-name">Help Centre</span>
        </div>

        <h1 class="hero__title">
          Frequently asked<br><em>questions</em>
        </h1>

        <p class="hero__sub" id="hero-sub">
          Everything you need to know about getting started and using your app.
        </p>

        <!-- Search — filters visible FAQ items in real time -->
        <div class="hero__search">
          <span class="hero__search-icon" aria-hidden="true">
            <svg width="18" height="18" viewBox="0 0 20 20" fill="none">
              <circle cx="9" cy="9" r="6.5" stroke="#aab0b8" stroke-width="1.8"/>
              <path d="M14 14l3.5 3.5" stroke="#aab0b8" stroke-width="1.8" stroke-linecap="round"/>
            </svg>
          </span>
          <input
            class="hero__search-input"
            type="search"
            placeholder="Search for answers…"
            aria-label="Search FAQ"
          />
        </div>

      </div>

      <!-- Wave separator -->
      <div class="hero__wave" aria-hidden="true">
        <svg viewBox="0 0 1440 56" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M0 56h1440V28C1200 0 960 56 720 56S240 0 0 28V56z" fill="#FBFBFB"/>
        </svg>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════
         BREADCRUMB
    ═══════════════════════════════════════════ -->
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="{{url 'home_page'}}">Home</a>
      <span class="breadcrumb__sep" aria-hidden="true">/</span>
      <span id="breadcrumb-app">FAQ</span>
    </nav>

    <!-- ═══════════════════════════════════════════
         FAQ BODY
    ═══════════════════════════════════════════ -->
    <div class="faq-wrap">

      <!-- Sidebar -->
      <aside class="faq-sidebar" aria-label="App selector">
        <p class="faq-sidebar__label">Browse by app</p>
        <ul class="app-switcher" role="list" id="app-switcher">
          <!-- Built by script.js -->
        </ul>

        <div class="sidebar-help" id="contact">
          <p class="sidebar-help__title">Can't find an answer?</p>
          <p class="sidebar-help__text">Our support team typically responds within one business day.</p>
          <a href="{{url 'new_request_page'}}" class="sidebar-help__link">
            Contact support
            <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        </div>
      </aside>

      <!-- Main FAQ — rendered by script.js -->
      <main class="faq-main" id="faq-main" aria-live="polite" aria-atomic="false">
      </main>

    </div>

    {{partial 'footer'}}

  </body>
</html>
