<header class="site-header">
  <div class="site-header__inner">

    <!-- Logo — swap the SVG for your <img src="{{asset 'logo.svg'}}"> if needed -->
    <a href="{{url 'home_page'}}" class="site-logo" aria-label="{{help_center.name}} home">
      <div class="site-logo__mark" aria-hidden="true">
        <svg viewBox="0 0 20 20" fill="none">
          <circle cx="10" cy="10" r="8" stroke="white" stroke-width="2"/>
          <path d="M7 10c0-1.66 1.34-3 3-3s3 1.34 3 3c0 1.3-.84 2.4-2 2.82V14" stroke="white" stroke-width="1.8" stroke-linecap="round"/>
          <circle cx="10" cy="16.5" r="1" fill="white"/>
        </svg>
      </div>
      <span class="site-logo__name">Help<span>Centre</span></span>
    </a>

    <!-- Nav -->
    <nav class="site-nav" aria-label="{{t 'site_navigation'}}">
      <a href="{{url 'home_page'}}" class="site-nav__link">Home</a>
      <a href="{{url 'new_request_page'}}" class="site-nav__link">Contact</a>
    </nav>

    <!-- Submit a request CTA -->
    <a href="{{url 'new_request_page'}}" class="header-cta">
      <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
        <path d="M14 2H2a1 1 0 00-1 1v9a1 1 0 001 1h3l2 2 2-2h5a1 1 0 001-1V3a1 1 0 00-1-1z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/>
      </svg>
      {{t 'submit_a_request'}}
    </a>

  </div>
</header>
