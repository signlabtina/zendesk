<!DOCTYPE html>
<html lang="{{locale}}" dir="{{page_dir}}">
  {{partial 'document_head'}}
  <body>

    {{partial 'header'}}

    <div class="page-wrap">
      <div class="error-page">
        <div class="error-page__code" aria-hidden="true">{{error_page.error_code}}</div>
        <h1 class="error-page__title">
          {{#is error_page.error_code 404}}
            Page not found
          {{else}}
            Something went wrong
          {{/is}}
        </h1>
        <p class="error-page__text">
          {{#is error_page.error_code 404}}
            The page you're looking for doesn't exist or may have been moved.
          {{else}}
            We ran into an unexpected error. Please try again or contact our support team.
          {{/is}}
        </p>
        <a href="{{url 'home_page'}}" class="error-page__link">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M10 3L5 8l5 5" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          Back to Help Centre
        </a>
      </div>
    </div>

    {{partial 'footer'}}

  </body>
</html>
